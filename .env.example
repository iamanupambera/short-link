# Application Configuration
PORT=3000
NODE_ENV=DEVELOPMENT
CLIENT_URL=http://localhost:3001
API_URL=http://localhost:3000
ACCESS_TOKEN_SECRET=youraccesstoken!!!!!!!!!!!!!!!!

# JWT Configuration
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=30d

# Security
BCRYPT_SALT_ROUNDS=12

# OTP Configuration
OTP_EXPIRY_SECONDS=300

# Database Configuration
# NOTE: DB_ROOT_PASSWORD is used by docker-compose for the MySQL container root password
DB_ROOT_PASSWORD=yourRootPassword
DB_USERNAME=root
DB_PASSWORD=yourPassword
DB=short_link
DB_PORT=21207
DB_HOST=localhost
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Performance and Network Configuration (Optional)
ANALYTICS_BATCH_SIZE=100
TRUST_PROXY=loopback

#Mail Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=youremail@gmail.com
MAIL_PASSWORD=ymnznbpqlcmhgfev
MAIL_ENCRYPTION=tls
MAIL_FROM=no_reply@short-link.com
MAIL_FROM_NAME=short-link

# Security Secrets
IP_SALT_SECRET=your_secure_ip_salt

# Super Admin Default Credentials (Optional, will default if not provided)
SUPER_ADMIN_EMAIL=superadmin@shortlink.com
SUPER_ADMIN_PASSWORD=SuperAdminSecurePassword123!
